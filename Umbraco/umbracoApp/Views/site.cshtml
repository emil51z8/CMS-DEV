@using Umbraco.Cms.Web.Common.PublishedModels;
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = null;
    var home = Model.Root();
    var menuItems = home.Children().Where(x => x.IsVisible());
}

<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.Value("title")</title>

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1.6;
            background: #f8fafc;
            color: #1e293b;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        .container {
            width: min(1100px, 90%);
            margin: 0 auto;
        }

        .navbar {
            background: #0f172a;
            color: white;
            padding: 1rem 0;
            position: sticky;
            top: 0;
        }

        .nav-inner {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 1.3rem;
            font-weight: bold;
        }

        .menu {
            display: flex;
            gap: 1.5rem;
            list-style: none;
        }

        .menu a {
            color: #e2e8f0;
            font-weight: 500;
            transition: 0.2s;
        }

        .menu a:hover,
        .menu a.active {
            color: #38bdf8;
        }

        .hero {
            background: linear-gradient(135deg, #0f172a, #1d4ed8);
            color: white;
            padding: 5rem 0;
        }

        .hero h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .hero p {
            font-size: 1.2rem;
            max-width: 700px;
            color: #dbeafe;
        }

        .content-section {
            padding: 4rem 0;
        }

        .card {
            background: white;
            padding: 2rem;
            border-radius: 18px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

        .card h2 {
            margin-bottom: 1rem;
            color: #0f172a;
        }

        .footer {
            margin-top: 4rem;
            background: #0f172a;
            color: #cbd5e1;
            padding: 2rem 0;
            text-align: center;
        }

        .richtext p {
            margin-bottom: 1rem;
        }

        .richtext ul,
        .richtext ol {
            margin-left: 1.5rem;
            margin-bottom: 1rem;
        }

        form label {
            font-weight: 600;
        }

        form input,
        form textarea {
            width: 100%;
            padding: 0.75rem;
            margin-top: 0.3rem;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            font-size: 1rem;
        }

        form button {
            padding: 0.8rem 1.2rem;
            background: #1d4ed8;
            color: white;
            border: none;
            border-radius: 10px;
            cursor: pointer;
        }

        form button:hover {
            background: #1e40af;
        }

        @@media (max-width: 768px) {
            .nav-inner {
                flex-direction: column;
                gap: 1rem;
            }

            .menu {
                flex-wrap: wrap;
                justify-content: center;
            }

            .hero h1 {
                font-size: 2.2rem;
            }
        }
    </style>
</head>
<body>

    <nav class="navbar">
        <div class="container nav-inner">
            <a href="@home.Url()" class="logo">Mit Website</a>

            <ul class="menu">
                <li>
                    <a href="@home.Url()" class="@(Model.Id == home.Id ? "active" : "")">Forside</a>
                </li>

                @foreach (var item in menuItems)
                {
                    <li>
                        <a href="@item.Url()" class="@(item.Id == Model.Id ? "active" : "")">
                            @item.Name
                        </a>
                    </li>
                }
            </ul>
        </div>
    </nav>

    <header class="hero">
        <div class="container">
            <h1>@Model.Value("title")</h1>

            @if (Model.HasValue("heroText"))
            {
                <p>@Model.Value("heroText")</p>
            }
        </div>
    </header>

    <main class="content-section">
        <div class="container">
            <div class="card">
                <div class="richtext">
                    @Model.Value("bodyText")
                    @if (Model.Name == "Om os" && Model.Children().Any())
{
    <div style="margin-top: 2rem;">
        <h2>Vores team</h2>

        <div style="display: flex; gap: 2rem; flex-wrap: wrap; margin-top: 1.5rem;">
            
            @foreach (var item in Model.Children())
            {
                var image = item.Value<Umbraco.Cms.Core.Models.MediaWithCrops>("image");

                <div style="text-align: center; max-width: 200px;">
                    
                    @if (image != null)
                    {
                        <img src="@image.Url()" style="width: 100%; border-radius: 12px;" />
                    }

                    <h3 style="margin-top: 0.5rem;">
                        Emil Peitsen
                    </h3>

                </div>
            }

        </div>
    </div>
}
                </div>
            </div>
        </div>
    </main>



  @if (Model.Name == "Kontakt")
{
    <section class="content-section" style="padding-top: 0;">
        <div class="container">
            <div class="card" style="margin-top: 2rem;">
                <h2>Kontakt os</h2>

                <form>
                    <div style="margin-bottom: 1rem;">
                        <label for="name">Navn</label>
                        <input type="text" id="name" name="name" />
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" />
                    </div>

                    <div style="margin-bottom: 1rem;">
                        <label for="message">Besked</label>
                        <textarea id="message" name="message" rows="5"></textarea>
                    </div>

                    <button type="submit">Send</button>
                </form>
            </div>
        </div>
    </section>
}

    <footer class="footer">
        <div class="container">
            <p>© @DateTime.Now.Year Emil Peitersen — bygget i Umbraco</p>
        </div>
    </footer>

</body>
</html>